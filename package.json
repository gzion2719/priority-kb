{
  "name": "priority-kb",
  "version": "0.0.1",
  "private": true,
  "description": "Agent-driven knowledge base for Priority ERP — ingestion + retrieval with citations.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "e2e": "vitest run --config vitest.e2e.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "eval": "tsx evals/run.ts",
    "eval:lint": "tsx evals/run.ts --lint-only",
    "revert:private": "node scripts/revert-to-private.mjs",
    "check": "node scripts/check-repo-public-banner.mjs && npm run lint && npm run format:check && npm run typecheck && npm run eval:lint && npm test",
    "pre-push": "npm run check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.97.1",
    "drizzle-orm": "^0.45.2",
    "js-tiktoken": "^1.0.21",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/lint": "^19.8.1",
    "@commitlint/load": "^19.8.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "dotenv": "16.4.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yaml": "^2.9.0"
  }
}
