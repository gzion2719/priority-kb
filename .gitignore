# Hebrew OCR spike (M1 L21) — input screenshots have customer data,
# output JSON/text contains the extracted Hebrew. Only .gitkeep anchors tracked.
spikes/hebrew-ocr/input/*
spikes/hebrew-ocr/output/*
!spikes/hebrew-ocr/input/.gitkeep
!spikes/hebrew-ocr/output/.gitkeep

